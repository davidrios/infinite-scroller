{
  "name": "wc-infinite-scroller",
  "version": "0.0.4",
  "description": "A native web-component implementation of an infinite scroller",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/davidrios/infinite-scroller.git"
  },
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/infinite-scroller.umd.cjs",
  "module": "./dist/infinite-scroller.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/infinite-scroller.js",
      "require": "./dist/infinite-scroller.umd.cjs"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "keywords": ["web-component", "custom-element", "infinite-scroll", "virtual-scroll", "wc"],
  "sideEffects": false,
  "author": "David Rios <david.rios.gomes@gmail.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/davidrios/infinite-scroller/issues"
  },
  "homepage": "https://github.com/davidrios/infinite-scroller",
  "devDependencies": {
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^16.5.0",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.50.1",
    "vite": "^7.3.0",
    "vite-plugin-dts": "^4.5.4"
  }
}
